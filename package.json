{
  "name": "snowdogs",
  "version": "1.0.0",
  "description": "Real-time winter road safety app for Canadian drivers",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client run dev",
    "mobile": "npm --prefix mobile run start --",
    "mobile:android": "npm --prefix mobile run android --",
    "mobile:android:studio": "npm --prefix mobile run android:studio --",
    "mobile:ios": "npm --prefix mobile run ios --",
    "mobile:web": "npm --prefix mobile run web --",
    "dev:android": "concurrently \"npm run server\" \"npm run mobile:android:studio\"",
    "build:client": "npm --prefix client run build",
    "typecheck:mobile": "npm --prefix mobile run typecheck",
    "install:all": "npm install && npm --prefix server install && npm --prefix client install && npm --prefix mobile install"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
